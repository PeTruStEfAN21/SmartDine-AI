# .env.example

# URL-ul proiectului Supabase (îl găsești la Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Cheia Anonimă / Publică (începe de obicei cu 'eyJ...')
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Cheia API pentru OpenAI (pentru agentul de AI)
OPENAI_API_KEY=your-openai-key-here